                    <div class="claim-meta">
                        <span>📅 ${formatDateShort(claim.fecha)}</span>
                        <span>🏪 ${claim.tienda}</span>
                        <span>🏭 ${claim.cedis}</span>
                        <span>⚡ ${claim.prioridad.toUpperCase()}</span>
                    </div>
                </div>
            `).join('');
        }

        // Filtros
        function filterByStatus(status, element) {
            currentFilter = status;
            document.querySelectorAll('.filter-chip').forEach(chip => chip.classList.remove('active'));
            element.classList.add('active');
            renderClaims();
        }

        function filterClaims() {
            renderClaims();
        }

        // Acciones
        function updateStatus(id, newStatus) {
            const claim = claimsData.find(c => c.id === id);
            if (claim) {
                claim.estado = newStatus;
                claim.historial.push({
                    fecha: new Date().toISOString(),
                    accion: newStatus === 'resuelto' ? 'Reclamo resuelto' : 'En proceso de atención',
                    usuario: 'Sistema'
                });
                showToast('Estado actualizado correctamente', '✓');
                showClaimDetail(id);
                renderStats();
            }
        }

        function deleteClaim(id) {
            const index = claimsData.findIndex(c => c.id === id);
            if (index > -1) {
                claimsData.splice(index, 1);
                closeModal();
                showToast('Reclamo eliminado', '🗑️');
                showDashboard();
            }

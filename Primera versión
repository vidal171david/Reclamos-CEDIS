            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('newClaimView').classList.remove('hidden');
            document.getElementById('newClaimView').classList.add('animate-fade-in');
            document.getElementById('claimDetailView').classList.add('hidden');
        }

        function showClaimDetail(id) {
            const claim = claimsData.find(c => c.id === id);
            if (!claim) return;

            document.getElementById('dashboardView').classList.add('hidden');
            document.getElementById('newClaimView').classList.add('hidden');
            document.getElementById('claimDetailView').classList.remove('hidden');
            
            const detailContent = document.getElementById('detailContent');
            

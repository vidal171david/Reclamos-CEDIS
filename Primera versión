        // Renderizar estadísticas con barras lineales compactas
        function renderStats() {
            const total = claimsData.length;
            const pendientes = claimsData.filter(c => c.estado === 'pendiente').length;
            const proceso = claimsData.filter(c => c.estado === 'proceso').length;
            const resueltos = claimsData.filter(c => c.estado === 'resuelto').length;

            const stats = [
                { 
                    label: 'Pendientes', 
                    value: pendientes, 
                    icon: '⏳', 
                    class: 'pendiente',
                    percent: total > 0 ? ((pendientes / total) * 100).toFixed(1) : 0
                },
                { 
                    label: 'En Proceso', 
                    value: proceso, 
                    icon: '🔄', 
                    class: 'proceso',
                    percent: total > 0 ? ((proceso / total) * 100).toFixed(1) : 0
                },
                { 
                    label: 'Resueltos', 
                    value: resueltos, 
                    icon: '✅', 
                    class: 'resuelto',
                    percent: total > 0 ? ((resueltos / total) * 100).toFixed(1) : 0
                },
                { 
                    label: 'Total', 
                    value: total, 
                    icon: '📊', 
                    class: 'total',
                    percent: '100.0'
                }
            ];

            const container = document.getElementById('statsContainer');
            container.innerHTML = stats.map(stat => `
                <div class="stat-bar-card">
                    <div class="stat-bar-header">
                        <div class="stat-bar-label">
                            <div class="stat-bar-icon ${stat.class}">${stat.icon}</div>
                            ${stat.label}
                        </div>
                        <div class="stat-bar-numbers">
                            <span class="stat-bar-value">${stat.value}</span>
                            <span class="stat-bar-percent">${stat.percent}%</span>
                        </div>
                    </div>
                    <div class="stat-bar-visual">
                        <div class="stat-bar-fill ${stat.class}" style="width: ${stat.percent}%; --target-width: ${stat.percent}%"></div>
                    </div>
                </div>
            `).join('');
        }

        // Renderizar lista
        function renderClaims() {
            const list = document.getElementById('claimsList');
            const searchTerm = document.getElementById('searchInput').value.toLowerCase();
            
            let filtered = claimsData;
            
            if (currentFilter !== 'todos') {
                filtered = filtered.filter(c => c.estado === currentFilter);
            }
            
            if (searchTerm) {
                filtered = filtered.filter(c => 
                    c.id.toLowerCase().includes(searchTerm) ||
                    c.productos.some(p => p.nombre.toLowerCase().includes(searchTerm)) ||
                    c.descripcion.toLowerCase().includes(searchTerm)
                );
            }

            filtered.sort((a, b) => new Date(b.fecha) - new Date(a.fecha));

            if (filtered.length === 0) {
                list.innerHTML = `
                    <div class="empty-state">
                        <div class="empty-icon">📭</div>
                        <div class="empty-title">No hay reclamos</div>
                        <div class="empty-text">No se encontraron reclamos con los filtros seleccionados</div>
                        <button class="btn btn-primary" onclick="showNewClaim()">Crear primer reclamo</button>
                    </div>
                `;
                return;
            }

            const estadoTexto = {
                'pendiente': 'Pendiente',
                'proceso': 'En Proceso',
                'resuelto': 'Resuelto'
            };

            list.innerHTML = filtered.map(claim => `
